{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/otp/layout,_N_T_/auth/otp/page,_N_T_/auth/otp"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/otp/__PAGE__",
    "/auth/otp",
    "/auth",
    "/_index",
    "/_head"
  ]
}