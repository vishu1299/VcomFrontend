{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/logout/layout,_N_T_/auth/logout/page,_N_T_/auth/logout"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/logout/__PAGE__",
    "/auth/logout",
    "/auth",
    "/_index",
    "/_head"
  ]
}