    },
    {
      "page": "/products",
      "regex": "^/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products(?:/)?$"
    },
    {
      "page": "/top-category",
      "regex": "^/top\\-category(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/top\\-category(?:/)?$"
    },
    {
      "page": "/wishlist",
      "regex": "^/wishlist(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/wishlist(?:/)?$"
    }
